# Stack Auth
# Get your project ID from https://app.stack-auth.com
VITE_STACK_PROJECT_ID=your_stack_project_id

# NOTE: VITE_STACK_SECRET_SERVER_KEY (ssk_...) is for backend only — never expose it in the frontend!
# Set it in your backend environment, not here.

# Backend API URL (default: production)
VITE_API_BASE_URL=https://livekit-outbound-api.tinysaas.fun
