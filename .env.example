# LiveKit Configuration
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret
LIVEKIT_URL=wss://your-subdomain.livekit.cloud
NEXT_PUBLIC_LIVEKIT_URL=wss://your-subdomain.livekit.cloud

# Vobiz SIP Configuration
SIP_DOMAIN=your-sip-domain.sip.vobiz.ai
VOBIZ_SIP_DOMAIN=your-sip-domain.sip.vobiz.ai
VOBIZ_SIP_USERNAME=your-sip-username
VOBIZ_SIP_PASSWORD=your-sip-password
VOBIZ_PHONE_NUMBER=+1234567890

# LiveKit SIP Trunk (Outbound)
# Preferred outbound trunk ID from LiveKit SIP configuration.
# Older deployments may still use LIVEKIT_OUTBOUND_TRUNK_ID or SIP_TRUNK_ID, but only this variable needs to be set.
LIVEKIT_SIP_TRUNK_ID=ST_nVvG7n8BpJd3
# Default destination used by the transfer_call tool when no explicit target is provided
DEFAULT_TRANSFER_NUMBER=+1234567890

# AI Service API Keys
DEEPGRAM_API_KEY=your-deepgram-api-key
OPENAI_API_KEY=sk-proj-your-openai-api-key
CARTESIA_API_KEY=sk_car_your-cartesia-api-key
SARVAM_API_KEY=your-sarvam-api-key
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile
DEEPGRAM_TTS_PROVIDER=deepgram
TTS_PROVIDER=cartesia # or sarvam or deepgram
OUTBOUND_AGENT_NAME=voice-assistant

# n8n MCP Integration
N8N_MCP_URL=https://your-n8n-instance.com/mcp/your-endpoint-id

# Neon Database
NEON_DATABASE_URL=postgresql://neondb_owner:password@host.neon.tech/neondb?sslmode=require

# Whispey Observability (Get from https://whispey.com)
WHISPEY_API_KEY=your-whispey-api-key
WHISPEY_AGENT_ID=your-agent-id-from-dashboard
